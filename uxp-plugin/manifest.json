{
  "id": "com.turkcealtyazi.premiere",
  "name": "TürkçeAltyazı",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": ["http://localhost:8787"]
    },
    "clipboard": "readAndWrite",
    "allowCodeGenerationFromStrings": true,
    "launchProcess": {
      "schemes": ["https"],
      "extensions": [".command", ".sh"]
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "turkcealtyazi.panel",
      "label": {
        "default": "TürkçeAltyazı"
      },
      "lifecycle": {
        "create": "panelCreate",
        "destroy": "panelDestroy"
      },
      "minimumSize": { "width": 300, "height": 500 },
      "maximumSize": { "width": 700, "height": 1200 },
      "preferredDockedSize": { "width": 340, "height": 600 },
      "preferredFloatingSize": { "width": 360, "height": 650 },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark"]
        }
      ]
    }
  ]
}
